# OmniScan-AI — copy to `.env` and adjust (never commit real secrets).
# `OMINSCAN_ZERODAY_SKIP_HWID=1` bypasses the Zero-Day HWID check for local/dev only.

OMNISCAN_DASHBOARD_SECRET=change-me-dashboard-session-secret
OMINSCAN_ZERODAY_HWID=00000000000000000000000000000000deadbeefcafe
OMINSCAN_ZERODAY_SKIP_HWID=1

# Optional: AI-Mutator (--ai-mutate per-parameter mode) OpenAI-compatible API
# OPENAI_API_KEY=sk-...
# OMINSCAN_OPENAI_API_KEY=sk-...
# OMINSCAN_OPENAI_MODEL=gpt-4o-mini
# OMINSCAN_OPENAI_BASE_URL=https://api.openai.com/v1
